{
  "name": "helmet-console",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Lightweight smart terminal console (host-side) for embedded devices via WebSocket relay.",
  "scripts": {
    "start": "node server/src/index.js",
    "lint": "eslint .",
    "smoke": "node server/scripts/smoke.js",
    "test": "npm run lint && npm run smoke",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "simple-git-hooks"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "prettier": "^3.0.0",
    "simple-git-hooks": "^2.11.0"
  },
  "simple-git-hooks": {
    "commit-msg": "npx --no-install commitlint --edit \"$1\""
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "sirv": "^3.0.2",
    "ws": "^8.20.0"
  }
}
